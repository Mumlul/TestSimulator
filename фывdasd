using System;
using System.IO.Ports;

class Program
{
    static void Main(string[] args)
    {
        Console.WriteLine("Введите COM-порт (например COM3):");
        string portName = Console.ReadLine() ?? "COM3";

        Console.WriteLine("Введите скорость (baud rate, например 9600):");
        int baudRate = int.TryParse(Console.ReadLine(), out int br) ? br : 9600;

        using SerialPort comPort = new SerialPort(portName, baudRate, Parity.None, 8, StopBits.One)
        {
            Handshake = Handshake.None,
            ReadTimeout = 500,
            WriteTimeout = 500
        };

        try
        {
            comPort.Open();
            Console.WriteLine($"Порт {portName} открыт. Чтение данных... (Ctrl+C для выхода)");

            comPort.DataReceived += (sender, e) =>
            {
                try
                {
                    string data = comPort.ReadExisting(); // читаем все доступные данные
                    if (!string.IsNullOrEmpty(data))
                        Console.WriteLine($"[{DateTime.Now:HH:mm:ss}] Получено: {data}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Ошибка при чтении: {ex.Message}");
                }
            };

            // Цикл, чтобы программа не завершилась
            while (true)
            {
                System.Threading.Thread.Sleep(100);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Не удалось открыть COM-порт: {ex.Message}");
        }
        finally
        {
            if (comPort.IsOpen)
            {
                comPort.Close();
                Console.WriteLine("COM-порт закрыт.");
            }
        }
    }
}
